# Supabase (leave unset to use in-memory demo store for local dev)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI: set to false and configure OPENAI_API_KEY when ready for live calls
AI_MOCK_MODE=true
